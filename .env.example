# Copy this to .env.local and fill in your values from Vercel Postgres dashboard
# Vercel auto-injects these when you link a Postgres database in the Vercel dashboard

POSTGRES_URL=postgres://user:password@host/dbname
POSTGRES_URL_NON_POOLING=postgres://user:password@host/dbname?sslmode=require
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_HOST=your_host
POSTGRES_DATABASE=your_database
